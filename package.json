{
  "name": "groundswell",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22.0.0 <27",
    "pnpm": ">=10.28.2 <11"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "pnpm run type-check && pnpm run lint && pnpm run test && next build",
    "build:next": "next build",
    "capture": "tsx scripts/capture.ts",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "prepare": "simple-git-hooks || true"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged && pnpm exec tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "eslint --max-warnings=0"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "d3-shape": "^3.2.0",
    "motion": "^12.40.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "server-only": "^0.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^22.10.5",
    "@types/react": "~19.2.15",
    "@types/react-dom": "~19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "happy-dom": "^20.8.9",
    "lint-staged": "^17.0.5",
    "postcss": "8.5.15",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.8.0",
    "vitest": "^4.1.4"
  }
}
