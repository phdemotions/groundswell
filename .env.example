# ─────────────────────────────────────────────────────────────────────────
# Groundswell — environment template
#
# Copy to .env.local for local dev (gitignored). In Vercel, set these in all
# three buckets (Development / Preview / Production) per U0 ops (GS-001).
# NEVER commit real values. The service-role key is server-only and must never
# be exposed with a NEXT_PUBLIC_ prefix.
# ─────────────────────────────────────────────────────────────────────────

# Supabase — own dedicated project (KTD11). URL + anon key are public-safe.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service-role key — SERVER ONLY. Bypasses RLS. Used solely by the capture
# path through src/lib/supabase/admin.ts (server-only-guarded). Never client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# GitHub fine-grained PAT (KTD5) — Administration:Read + Contents:Read +
# Metadata:Read, read-only, scoped to tracked repos, 90-day TTL.
# Required (non-empty) only when CAPTURE_ENABLED=true.
GITHUB_TOKEN=github_pat_...

# Vercel Cron shared secret (KTD3/KTD10) — compared with timingSafeEqual on the
# capture route. Required (non-empty, min length) when CAPTURE_ENABLED=true.
CRON_SECRET=

# Capture master switch (KTD10). Default OFF until U0 ops verify the token,
# secrets, and Fluid Compute. The cron route no-ops while false.
CAPTURE_ENABLED=false

# Public base URL of the deployed app (used for absolute links / OG export).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry (optional — observability). Leave blank to disable.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
